# YouTube Summarizer Configuration
# Copy this file to .env and fill in your values

# Required: Your OpenAI API key
OPENAI_API_KEY=your-api-key-here

# Optional: Custom API endpoint (for OpenAI-compatible APIs like Ollama, Together AI, LM Studio, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Default model to use for summarization (can be overridden with --model flag)
# OPENAI_MODEL=gpt-4o-mini

# Required CLI tools:
# - For YouTube videos: yt-dlp, ffmpeg, parakeet-mlx
# - For web pages: defuddle
