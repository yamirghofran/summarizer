# YouTube Summarizer Configuration
# Copy this file to .env and fill in your values

# ============================================
# OpenAI API Configuration (Required)
# ============================================

# Required: Your OpenAI API key
OPENAI_API_KEY=your-api-key-here

# Optional: Custom API endpoint (for OpenAI-compatible APIs like Ollama, Together AI, LM Studio, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Default model to use for summarization (can be overridden with --model flag)
# OPENAI_MODEL=gpt-4o-mini

# ============================================
# Telegram Bot Configuration (Required for bot mode)
# ============================================

# Required: Your Telegram bot token from @BotFather
# Get it by messaging @BotFather on Telegram and creating a new bot
# TELEGRAM_BOT_TOKEN=your-bot-token-here

# Optional: Comma-separated list of allowed Telegram user IDs
# If not set, the bot will be open to everyone
# Get your user ID by messaging @userinfobot on Telegram
# ALLOWED_USER_IDS=123456789,987654321

# ============================================
# Required CLI Tools
# ============================================

# For YouTube videos:
#   - yt-dlp (https://github.com/yt-dlp/yt-dlp)
#   - ffmpeg (https://ffmpeg.org)
#   - parakeet-mlx (for transcription)
#
# For web pages:
#   - defuddle (for content extraction)
